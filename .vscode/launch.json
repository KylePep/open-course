{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run API (tsx + inspect)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "args": ["apps/api/src/index.ts"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "restart": true,
      "envFile": "${workspaceFolder}/apps/api/.env"
    },
    {
      "name": "Attach API Debugger",
      "type": "pwa-node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
